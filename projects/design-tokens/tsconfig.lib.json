/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/lib",
    "declaration": true,
    "declarationMap": true,
    /* Ver la nota en `projects/ui-smartcontact/tsconfig.lib.json`: `inlineSources`
     * exige `sourceMap`, y sin él este fichero solo es válido si quien lo usa
     * pasa `--sourceMap` a mano. Los tres proyectos tenían el mismo defecto. */
    "sourceMap": true,
    "inlineSources": true,
    "types": []
  },
  "exclude": [
    "**/*.spec.ts"
  ]
}
