{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "design-tokens": {
      "projectType": "library",
      "root": "projects/design-tokens",
      "sourceRoot": "projects/design-tokens/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/design-tokens/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/design-tokens/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/design-tokens/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "ui-smartcontact-icons": {
      "projectType": "library",
      "root": "projects/ui-smartcontact-icons",
      "sourceRoot": "projects/ui-smartcontact-icons/src",
      "prefix": "sc",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/ui-smartcontact-icons/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ui-smartcontact-icons/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ui-smartcontact-icons/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "ui-smartcontact": {
      "projectType": "library",
      "root": "projects/ui-smartcontact",
      "sourceRoot": "projects/ui-smartcontact/src",
      "prefix": "sc",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ui-smartcontact/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ui-smartcontact/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ui-smartcontact/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ui-smartcontact/tsconfig.spec.json",
            "runner": "vitest",
            "include": [
              "**/*.spec.ts"
            ]
          }
        }
      }
    },
    "sc-demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/sc-demo",
      "sourceRoot": "projects/sc-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/sc-demo",
            "index": "projects/sc-demo/src/index.html",
            "main": "projects/sc-demo/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/sc-demo/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/sc-demo/public",
                "output": "/"
              }
            ],
            "styles": [
              "projects/sc-demo/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "650kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "14kB",
                  "maximumError": "18kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "sc-demo:build:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "sc-demo:build:production"
            },
            "development": {
              "buildTarget": "sc-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        }
      }
    },
    "supervisor": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/supervisor",
      "sourceRoot": "projects/supervisor/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/supervisor",
            "index": "projects/supervisor/src/index.html",
            "browser": "projects/supervisor/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/supervisor/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/supervisor/public"
              },
              {
                "glob": "**/*",
                "input": "projects/supervisor/src/assets",
                "output": "/assets"
              }
            ],
            "styles": [
              "projects/supervisor/src/styles/main.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2.5MB",
                  "maximumError": "5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "16kB",
                  "maximumError": "24kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "supervisor:build:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "supervisor:build:production"
            },
            "development": {
              "buildTarget": "supervisor:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "agent": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/agent",
      "sourceRoot": "projects/agent/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/agent",
            "index": "projects/agent/src/index.html",
            "browser": "projects/agent/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/agent/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/agent/public"
              }
            ],
            "styles": [
              "projects/agent/src/styles/main.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2.5MB",
                  "maximumError": "5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "16kB",
                  "maximumError": "24kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "agent:build:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "agent:build:production"
            },
            "development": {
              "buildTarget": "agent:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
